      { "attr": "allow_access",   "name": "允许外部访问", "type": "checkbox", "default": true, "suffix": "允许直接通过主机IP+端口访问", "unit": "" },
      { "attr": "cpus",           "name": "CPU核心限制",  "type": "number",   "default": 0,    "suffix": "0为不限制", "unit": "" },
