    "appdesc": "Rybbit 是 Google Analytics 的开源且隐私友好的替代方案，更加直观易用。",
    "appstatus": 1,
    "icon": "",
    "sort": 0,
    "home": "https://github.com/rybbit-io/rybbit",
    "help": "https://github.com/rybbit-io/rybbit",
    "cpu": 0,
    "mem": 0,
    "disk": 10240,
    "updateat": 1767024085,
    "installed": false,
    "reuse": true,
    "depend": null,
    "field": [
        {"attr": "domain", "name": "域名", "type": "textarea", "default": "", "suffix": "浏览器访问的域名,非必填", "unit": ""},
        {"attr": "allow_access", "name": "允许外部访问", "type": "checkbox", "default": true, "suffix": "允许直接通过主机IP+端口访问", "unit": ""},
        {"attr": "rybbit_caddy_http_port", "name": "HTTP端口", "type": "number", "default": 8080, "suffix": "HTTP端口", "unit": ""},
        {"attr": "rybbit_caddy_https_port", "name": "HTTPS端口", "type": "number", "default": 8443, "suffix": "HTTPS端口(请使用https+该端口访问)", "unit": ""},
        {"attr": "base_url", "name": "基础URL", "type": "text", "default": "https://ip:8443", "suffix": "请使用https 否则无法登陆", "unit": ""},
        {"attr": "cpus", "name": "cpu核心数限制", "type": "number", "default": 0, "suffix": "0为不限制,最大可用核心数为: ", "unit": ""},
        {"attr": "memory_limit", "name": "内存限制", "type": "number", "default": 0, "suffix": "0为不限制,最大可用内存为: ", "unit": ""}
    ],
    "env": [
        {"key": "version", "type": "string", "default": null, "desc": "版本号"},
        {"key": "host_ip", "type": "string", "default": null, "desc": "主机IP"},
        {"key": "app_path", "type": "path", "default": null, "desc": "应用数据目录"},
        {"key": "rybbit_caddy_http_port", "type": "port", "default": 8080, "desc": "HTTP端口"},
        {"key": "rybbit_caddy_https_port", "type": "port", "default": 8443, "desc": "HTTPS端口"},
        {"key": "base_url", "type": "string", "default": "https://demo.rybbit.com", "desc": "基础URL"},
        {"key": "cpus", "type": "number", "default": null, "desc": "CPU核心数限制"},
        {"key": "memory_limit", "type": "number", "default": null, "desc": "内存大小限制"}
    ],
    "volumes": {
        "data": {"type": "path", "desc": "应用数据目录"}
    }
